@using Microsoft.AspNetCore.Identity
@using Microsoft.AspNetCore.Mvc.Localization
@using Microsoft.Extensions.Options
@inject IViewLocalizer Localizer
@model Skoruba.Duende.IdentityServer.STS.Identity.ViewModels.Account.ForgotPasswordViewModel
@inject IOptions<IdentityOptions> IdentityOptions
@{
    Layout = "_LayoutAuth";

    ViewData["Title"] = Localizer["Title"];
}

@await Html.PartialAsync("_ValidationSummary")

<div class="row justify-content-center">
    <div class="col-11 col-sm-10 col-md-7 col-lg-5 col-xl-5">
        <div class="card shadow">
            <div class="card-body p-4">
                <h5 class="card-title text-center mb-4">@Localizer["Title"]</h5>
                @if (IdentityOptions.Value.User.RequireUniqueEmail)
                {
                    <p class="text-muted text-center mb-4">@Localizer["ChoosePolicy"]</p>
                }
                else
                {
                    <p class="text-muted text-center mb-4">@Localizer["UsernamePolicy"]</p>
                }
                <form asp-controller="Account" asp-action="ForgotPassword" method="post" autocomplete="on" id="recoveryForm" novalidate>
                    @if (IdentityOptions.Value.User.RequireUniqueEmail)
                    {
                        <div class="d-flex justify-content-center mb-4">
                            <div class="form-check me-3">
                                <input type="radio" id="emailPolicy" asp-for="Policy" value="Email" class="form-check-input" checked />
                                <label class="form-check-label" for="emailPolicy">
                                    @Localizer["LocateEmail"]
                                </label>
                            </div>
                            <div class="form-check">
                                <input type="radio" id="userPolicy" asp-for="Policy" value="Username" class="form-check-input" />
                                <label class="form-check-label" for="userPolicy">
                                    @Localizer["LocateUsername"]
                                </label>
                            </div>
                        </div>
                    }
                    else
                    {
                        <div class="d-none">
                            <input type="hidden" id="userPolicy" asp-for="Policy" value="Username" />
                        </div>
                    }                    

                    @if (IdentityOptions.Value.User.RequireUniqueEmail)
                    {
                        <div class="form-group mb-4" id="emailField">
                            <div class="input-group">
                                <span class="input-group-text input-icon">
                                    <i class="fas fa-envelope"></i>
                                </span>
                                <input asp-for="Email" class="form-control" placeholder="@Localizer["Email"]" required />
                                <div class="invalid-feedback">
                                    @Localizer["ValidationEmail"]
                                </div>
                            </div>
                        </div>
                    }
                                            
                    <div class="form-group mb-4 @(IdentityOptions.Value.User.RequireUniqueEmail?"d-none":string.Empty)" id="usernameField">
                        <div class="input-group">
                            <span class="input-group-text input-icon">
                                <i class="fas fa-user"></i>
                            </span>
                            <input asp-for="Username" class="form-control" placeholder="@Localizer["Username"]" required />
                            <div class="invalid-feedback">
                                @Localizer["ValidationUsername"]
                            </div>
                        </div>
                    </div>

                    <div class="d-grid">
                        <button type="button" class="btn btn-primary register"><i class="fa fa-check"></i>&nbsp;@Localizer["Submit"]</button>
                    </div>                
                </form>
            </div>
        </div>
    </div>
</div>

@section scripts {
    <environment include="Development">
        <script src="~/dist/js/account_forgotpassword.js"></script>
    </environment>
    <environment exclude="Development">
        <script src="~/dist/js/account_forgotpassword.min.js"></script>
    </environment>
}