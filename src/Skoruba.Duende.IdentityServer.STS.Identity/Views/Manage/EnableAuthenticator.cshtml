@inject IViewLocalizer Localizer
@using Microsoft.AspNetCore.Mvc.Localization
@model Skoruba.Duende.IdentityServer.STS.Identity.ViewModels.Manage.EnableAuthenticatorViewModel
@{
    ViewData["Title"] = Localizer["Title"];
}

<!-- Main title -->
<div class="d-flex align-items-center mb-4">
    <i class="fas fa-qrcode fa-2x text-primary me-3"></i>
    <h2 class="mb-0">@ViewData["Title"]</h2>
</div>

<div class="alert alert-info d-flex align-items-center mt-4">
    <div>
        <p class="mb-0">@Localizer["SubTitle"]</p>
    </div>
</div>    

<!-- Step 1 -->
<div class="card shadow-sm mb-4">
    <div class="card-header bg-white">
        <h5 class="mb-0"><i class="badge bg-primary rounded-pill me-2">1</i> @Localizer["Step1"]</h5>
    </div>
    <div class="card-body">
        <p class="card-text">
            @Localizer["DownloadTitle"]
            <a href="https://go.microsoft.com/fwlink/?Linkid=825071">Windows Phone</a>,
            <a href="https://go.microsoft.com/fwlink/?Linkid=825072">Android</a>,
            <a href="https://go.microsoft.com/fwlink/?Linkid=825073">iOS</a>.
            @Localizer["GoogleAuthenticatorTitle"]
            <a href="https://play.google.com/store/apps/details?id=com.google.android.apps.authenticator2&amp;hl=en">Android</a>,
            <a href="https://itunes.apple.com/us/app/google-authenticator/id388497605?mt=8">iOS</a>.
        </p>
    </div>
</div>

<!-- Step 2 -->
<div class="card shadow-sm mb-4">
    <div class="card-header bg-white">
        <h5 class="mb-0"><i class="badge bg-primary rounded-pill me-2">2</i> @Localizer["Step2"]</h5>
    </div>
    <div class="card-body">
        <p class="card-text">@Localizer["ScanQR"] <kbd>@Model.SharedKey</kbd> @Localizer["ScanQRSubTitle"]</p>
        <div class="row align-items-center">
            <div class="col-12 col-md-6-xxx text-center text-md-start-xxx mb-3 mb-md-0">
                <div id="qrCode" class="d-inline-block"></div>
                <div id="qrCodeData" data-url="@Html.Raw(Model.AuthenticatorUri)"></div>
            </div>
        </div>
    </div>
</div>
<!-- Step 3 -->
<div class="card shadow-sm">
    <div class="card-header bg-white">
        <h5 class="mb-0"><i class="badge bg-primary rounded-pill me-2">3</i> @Localizer["Step3"]</h5>
    </div>
    <div class="card-body">
        <p class="card-text">@Localizer["Info"]</p>
        <div class="col-md-6">
            <form method="post">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger mb-3 p-2"></div>
                <div class="mb-3">
                    <label asp-for="Code" class="form-label">@Localizer["Code"]</label>
                    <div class="input-group">
                        <span class="input-group-text"><i class="fas fa-key"></i></span>
                        <input asp-for="Code" class="form-control" autocomplete="off" placeholder="@Localizer["VerifCodePlaceholder"]" />
                    </div>
                    <span asp-validation-for="Code" class="text-danger"></span>
                </div>
                <button type="submit" class="btn btn-primary"><i class="fas fa-check-circle me-2"></i>@Localizer["Verify"]</button>
            </form>
        </div>
    </div>
</div>

@section scripts {
    <script src="~/js/qrcode.min.js"></script>
    <script type="text/javascript">
        new QRCode(document.getElementById("qrCode"),
            {
                text: "@Html.Raw(Model.AuthenticatorUri)",
                width: 200,
                height: 200,
                correctLevel: QRCode.CorrectLevel.H
            });
    </script>
}
